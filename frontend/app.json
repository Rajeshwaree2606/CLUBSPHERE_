{
  "expo": {
    "name": "ClubSphere",
    "slug": "clubsphere",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#3730a3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clubsphere.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3730a3"
      },
      "package": "com.clubsphere.app",
      "versionCode": 1,
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "ad440a75-a46c-4ed5-8cf8-65ad3102a5ea"
      }
    }
  }
}
